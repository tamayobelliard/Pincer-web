# Pincer Environment Variables
# Copy this to .env.local for local development
# IMPORTANT: Use a SEPARATE Supabase project for development!

# Supabase — use your DEV project, NOT production
SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-dev-service-role-key

# Anthropic (Claude API for menu extraction)
ANTHROPIC_API_KEY=your-anthropic-key

# Resend (transactional emails)
RESEND_API_KEY=your-resend-key

# Google reCAPTCHA v3
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# Firebase Cloud Messaging (server key for push notifications)
FCM_SERVER_KEY=your-fcm-server-key

# Cron job authentication
CRON_SECRET=your-cron-secret

# Azul payment gateway
AZUL_AUTH1=your-azul-auth1
AZUL_AUTH2=your-azul-auth2
AZUL_MERCHANT_ID=your-merchant-id
AZUL_CHANNEL=EC

# Environment (set to 'production' in Vercel)
NODE_ENV=development
